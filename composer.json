{
    "name": "track-any-device/drivers",
    "description": "Device drivers and connectors for the Track Any Device platform.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^13.7",
        "track-any-device/core": "^0.8.0",
        "track-any-device/sms-gateway": "*"
    },
    "autoload": {
        "psr-4": {
            "TrackAnyDevice\\Drivers\\": "src/"
        }
    },
    "repositories": [
{
            "type": "path",
            "url": "../package-sms-gateway",
            "options": {
                "symlink": true
            }
        }
    ],
    "extra": {
        "laravel": {
            "providers": [
                "TrackAnyDevice\\Drivers\\DriversServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
